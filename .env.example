# Convex deployment URL (set by init_app_project tool or npx convex dev)
VITE_CONVEX_URL=
VITE_CONVEX_SITE_URL=

# For local development with npx convex dev
# CONVEX_DEPLOY_KEY=
# CONVEX_DEPLOYMENT=

# Auth private key (RSA 2048, generated automatically)
# JWT_PRIVATE_KEY=
# JWKS=

# Server-side Convex environment variables (set in Convex dashboard, not in client bundles)
# SITE_URL=
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# OPENAI_API_KEY=
# RESEND_API_KEY=
# AUTH_EMAIL_FROM=AquaReport <hello@aquareport.org>
# AUTH_EMAIL_REPLY_TO=support@aquareport.org
# SENTRY_DSN=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# HUBSPOT_CLIENT_ID=
# HUBSPOT_CLIENT_SECRET=
# GOHIGHLEVEL_CLIENT_ID=
# GOHIGHLEVEL_CLIENT_SECRET=
# SALESFORCE_CLIENT_ID=
# SALESFORCE_CLIENT_SECRET=
